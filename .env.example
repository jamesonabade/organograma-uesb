# ==========================================
# ARQUIVO DE VARIÁVEIS DE AMBIENTE - MODELO
# ==========================================
# Renomeie este arquivo para .env em produção e preencha com seus dados

# 1. Fonte de Dados Principal (Escolha: 'db' ou 'api')
DATA_SOURCE=api

# 2. Configurações de API (Obrigatório se DATA_SOURCE=api)
API_AUTH_URL=https://autenticacao.sigdev.uesb.br/authz-server/oauth/token
API_BASE_URL=https://api.sigdev.uesb.br/unidade/v1/unidades
API_CLIENT_ID=seu_client_id_aqui
API_CLIENT_SECRET=seu_client_secret_aqui
API_KEY=sua_api_key_aqui

# 3. Configurações de Banco de Dados (Obrigatório se DATA_SOURCE=db)
DB_USER=postgres
DB_HOST=seu_host_banco
DB_DATABASE=sistemas_comum
DB_PASSWORD=sua_senha
DB_PORT=5432

# 4. Otimização e Performance
# Tempo de cache em minutos. Defina como 0 ou deixe em branco para tempo real (instantâneo).
CACHE_TTL_MINUTES=60
